<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <!-- Denegar acceso a esta carpeta -->
        <security>
            <requestFiltering>
                <hiddenSegments>
                    <add segment="sessions" />
                </hiddenSegments>
            </requestFiltering>
        </security>
        <handlers>
            <clear />
            <add name="DenyAll" path="*" verb="*" type="" modules="" scriptProcessor="" resourceType="Unspecified" requireAccess="None" allowPathInfo="false" preCondition="" />
        </handlers>
    </system.webServer>
</configuration>
